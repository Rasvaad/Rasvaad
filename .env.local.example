# ── Sanity ────────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Create a "Viewer" token at sanity.io/manage → API → Tokens
# Used for server-side fetches (not exposed to browser)
SANITY_API_TOKEN=your_viewer_token_here

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# The Gmail account that SENDS the email
EMAIL_USER=your.gmail@gmail.com

# Use an App Password, NOT your real password
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=your_16_char_app_password

# Where to RECEIVE the inquiry emails (defaults to rasvaad@gmail.com if not set)
EMAIL_TO=rasvaad@gmail.com
